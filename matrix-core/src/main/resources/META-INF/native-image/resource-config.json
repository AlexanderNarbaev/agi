{
  "resources": {
    "includes": [
      {
        "pattern": ".*\\.properties$"
      },
      {
        "pattern": ".*\\.avsc$"
      },
      {
        "pattern": ".*\\.avro$"
      },
      {
        "pattern": "db/migration/.*\\.sql$"
      },
      {
        "pattern": "META-INF/.*"
      },
      {
        "pattern": "models/.*"
      },
      {
        "pattern": "pretrained/.*"
      },
      {
        "pattern": ".*SmolLM2.*"
      },
      {
        "pattern": ".*\\.json$"
      },
      {
        "pattern": ".*\\.yaml$"
      },
      {
        "pattern": ".*\\.yml$"
      }
    ]
  },
  "bundles": [
    {
      "name": "sun.text.resources.cldr.FormatData",
      "locales": ["en", "ru"]
    }
  ]
}
