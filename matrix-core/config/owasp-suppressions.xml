<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        OWASP Dependency-Check Suppressions for MATRIX
        Add known false positives here with justification
    -->

    <!-- Quarkus internal dependencies — managed by Quarkus BOM -->
    <suppress>
        <notes><![CDATA[
            Quarkus platform BOM manages transitive dependency versions.
            Individual CVEs in transitive deps are mitigated by Quarkus patches.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.quarkus\..*@.*$</packageUrl>
        <cpe regex="true">^cpe:/a:.*$</cpe>
    </suppress>

    <!-- Pekko actor framework — managed by Pekko BOM -->
    <suppress>
        <notes><![CDATA[
            Apache Pekko 1.6.0 dependencies managed by pekko-bom.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.pekko\..*@.*$</packageUrl>
        <cpe regex="true">^cpe:/a:.*$</cpe>
    </suppress>

    <!-- Test dependencies — not shipped in production -->
    <suppress>
        <notes><![CDATA[
            Test-only dependencies (testcontainers, junit, assertj) are not
            included in the production artifact.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.testcontainers\..*@.*$</packageUrl>
    </suppress>
    <suppress>
        <notes><![CDATA[
            Test-only dependency.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.quarkus:quarkus-junit5@.*$</packageUrl>
    </suppress>
    <suppress>
        <notes><![CDATA[
            Test-only dependency.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.assertj:assertj-core@.*$</packageUrl>
    </suppress>
</suppressions>
