# MATRIX Core — Dev Docker build (multi-stage)
# Builds inside container, no pre-build required
# Usage: docker compose -f docker-compose.yml up --build matrix-core

# ─── Stage 1: Build ───
FROM eclipse-temurin:25-jdk AS build
WORKDIR /workspace

# Copy Gradle wrapper and config first (layer caching)
COPY gradlew gradlew.bat ./
COPY gradle/ gradle/
COPY gradle.properties settings.gradle build.gradle ./

# Copy subproject build files
COPY matrix-core/build.gradle matrix-core/build.gradle

# Copy source code
COPY matrix-core/src/ matrix-core/src/

# Make wrapper executable and build uber-jar
RUN chmod +x gradlew && \
    ./gradlew :matrix-core:quarkusBuild \
        -Dquarkus.package.jar.type=uber-jar \
        --no-daemon \
        -x test

# ─── Stage 2: Runtime ───
FROM eclipse-temurin:25-jre AS runtime
WORKDIR /app

# Copy built JAR from build stage
COPY --from=build /workspace/matrix-core/build/matrix-core-*-runner.jar /app/matrix-core.jar

# Copy pretrained models (SmolLM2-135M synth neurons + any other weights)
COPY models/pretrained/ /app/models/pretrained/

# Quarkus HTTP + Micrometer Prometheus
EXPOSE 8080 9091

# Health check via SmallRye Health endpoint (quarkus-smallrye-health)
HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -sf http://localhost:8080/q/health || exit 1

ENTRYPOINT ["java", "-Xmx512m", "-jar", "/app/matrix-core.jar"]
